---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryGrid from '../../components/GalleryGrid.astro';
const base = import.meta.env.BASE_URL;

const images = [
  { src: base + '/images/birds/_13I0175 copy.jpg', alt: 'Wild bird photograph' },
  { src: base + '/images/birds/_13I0596 copy.jpg', alt: 'Wild bird photograph' },
  { src: base + '/images/birds/_13I0607 copy.jpg', alt: 'Wild bird photograph' },
  { src: base + '/images/birds/_13I0607-2.jpg', alt: 'Wild bird photograph' },
  { src: base + '/images/birds/_13I1678.jpg', alt: 'Wild bird photograph' },
];
---

<BaseLayout title="Birds">
  <section class="category-hero" style={`background-image: url('${base}/images/birds/_13I0175%20copy.jpg');`}>
    <div class="category-hero-overlay"></div>
    <div class="category-hero-content">
      <h1>Birds</h1>
      <p><a href={base + '/gallery'} class="back-link">&larr; All Galleries</a></p>
    </div>
  </section>
  <GalleryGrid images={images} />
</BaseLayout>

<style>
  .category-hero {
    position: relative;
    height: 45vh;
    min-height: 300px;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
  }

  .category-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.1) 0%, rgba(10,10,10,0.7) 100%);
    pointer-events: none;
  }

  .category-hero-content {
    position: relative;
    z-index: 1;
    padding: 48px 32px;
  }

  .category-hero-content h1 {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: #fff;
  }

  .back-link {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }
</style>
